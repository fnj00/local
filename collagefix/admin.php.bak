<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Collage Admin</title>

    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            margin: 20px;
            background: #111;
            color: #fff;
        }

        .panel {
            max-width: 700px;
            padding: 20px;
            border-radius: 10px;
            background: #1d1d1d;
            box-shadow: 0 0 12px rgba(0,0,0,0.35);
        }

        label {
            display: block;
            margin-bottom: 8px;
            font-weight: bold;
        }

        input[type="range"] {
            width: 100%;
        }

        .value {
            margin-top: 10px;
            font-size: 18px;
        }

        .actions {
            margin-top: 25px;
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        button, a.button {
            background: #0d6efd;
            color: #fff;
            border: none;
            padding: 12px 16px;
            border-radius: 8px;
            text-decoration: none;
            cursor: pointer;
            display: inline-block;
        }

        button:hover, a.button:hover {
            background: #0b5ed7;
        }

        .note {
            margin-top: 16px;
            color: #ccc;
            line-height: 1.5;
        }
    </style>
</head>
<body>
    <div class="panel">
        <h1>Collage Admin</h1>

        <label for="opacityRange">Photo overlay opacity</label>
        <input id="opacityRange" type="range" min="0" max="100" step="1" value="40">
        <div class="value">Current opacity: <span id="opacityValue">40%</span></div>

        <div class="actions">
            <a id="downloadVisible" class="button" href="#" target="_blank" rel="noopener">Download Current Canvas</a>
            <a id="downloadOriginal" class="button" href="#" target="_blank" rel="noopener">Download Full Canvas (Original Tile Resolution)</a>
            <a id="downloadTileFull" class="button" href="#" target="_blank" rel="noopener">Download Full Canvas (Original Tile Resolution)</a>
	</div>

        <div class="note">
            Use the first download option for a browser-sized export. Use the second option to generate a mosaic PNG at the original combined tile resolution based on the event image width/height.
        </div>
    </div>

    <script>
        const urlParams = new URLSearchParams(window.location.search);
        const eventId = urlParams.get('id') || '0';

        const opacityRange = document.getElementById('opacityRange');
        const opacityValue = document.getElementById('opacityValue');
        const downloadVisible = document.getElementById('downloadVisible');
        const downloadOriginal = document.getElementById('downloadOriginal');
        const downloadTileFull = document.getElementById('downloadTileFull');

	function updateLinks() {
	    downloadVisible.href = `export.php?id=${encodeURIComponent(eventId)}&mode=visible`;
	    downloadOriginal.href = `export.php?id=${encodeURIComponent(eventId)}&mode=original`;
	    downloadTileFull.href = `export.php?id=${encodeURIComponent(eventId)}&mode=tilefull`;
	}

        function loadSettings() {
            fetch('data/collageSettings.php')
                .then(res => res.json())
                .then(settings => {
                    const opacity = typeof settings.opacity !== 'undefined' ? settings.opacity : 0.40;
                    const percent = Math.round(parseFloat(opacity) * 100);
                    opacityRange.value = percent;
                    opacityValue.textContent = `${percent}%`;
                });
        }

        function saveSettings(opacity) {
            const body = new URLSearchParams();
            body.append('opacity', opacity);

            fetch('data/collageSettings.php', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: body.toString()
            });
        }

        opacityRange.addEventListener('input', function () {
            const percent = parseInt(this.value, 10);
            const opacity = (percent / 100).toFixed(2);
            opacityValue.textContent = `${percent}%`;
            saveSettings(opacity);
        });

        updateLinks();
        loadSettings();
    </script>
</body>
</html>
